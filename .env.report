# ============================================================================
# LLM Provider Configuration
# Supported: openai, deepseek, google, anthropic, xai, qwen, glm, openrouter
# ============================================================================

# Provider selection
LLM_PROVIDER=deepseek

# Model settings (default: deepseek-chat for deepseek)
# DeepSeek models: deepseek-chat, deepseek-coder
# OpenAI models: gpt-5.4, gpt-4o, gpt-4o-mini
# Google models: gemini-2.0-flash, gemini-pro
# Anthropic models: claude-sonnet-4-20250514, claude-haiku-3-20240307
# xAI models: grok-4, grok-2
# Qwen models: qwen-turbo, qwen-plus
# GLM models: glm-4-flash, glm-4
DEEP_THINK_LLM=deepseek-chat
QUICK_THINK_LLM=deepseek-chat

# ============================================================================
# API Keys - set only the one matching your provider
# ============================================================================

# DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key

# Anthropic: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Google: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_google_api_key

# xAI (Grok): https://console.x.ai/
# XAI_API_KEY=your_xai_api_key

# Qwen (Alibaba): https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=your_dashscope_api_key

# GLM: https://open.bigmodel.cn/
# ZHIPU_API_KEY=your_zhipu_api_key

# OpenRouter: https://openrouter.ai/
# OPENROUTER_API_KEY=your_openrouter_api_key

# ============================================================================
# Telegram Configuration
# Get bot token from @BotFather on Telegram
# ============================================================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================================================
# Email Configuration (SMTP)
# For Gmail: Use App Password (16 chars)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# ============================================================================
# Optional: Custom Data Directory
# ============================================================================
# TRADINGAGENTS_RESULTS_DIR=/path/to/results
# TRADINGAGENTS_CACHE_DIR=/path/to/cache